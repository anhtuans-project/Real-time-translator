# Copy this file to `.env` and fill in values. `.env` is gitignored.
# All optional — backend runs local-CPU by default when these are empty.

# Offload ASR to a GPU server (gpu_cloud/asr_server.py on a GPU VPS).
# Use the WS URL of the GPU server — either its public address, or a tunnel
# (Cloudflare/ngrok) if the VPS has no public IP, e.g.:
#   wss://<gpu-host>:8000/asr          (direct, public IP / Tailscale)
#   wss://abcd-efg.trycloudflare.com/asr (via Cloudflare quick tunnel)
# Leave empty to run whisper-medium locally on CPU.
ASR_REMOTE_URL=

# Offload MT (translation) to Ollama on the same GPU server (asr_server.py proxies /api/* to Ollama).
# MT_BASE_URL = the http(s) base URL of the GPU server (same host as ASR_REMOTE_URL).
# MT_MODEL = the Ollama model name you `ollama pull`-ed on the GPU server.
# Leave MT_BASE_URL empty to use local Ollama (http://localhost:11434, qwen2.5:1.5b).
MT_BASE_URL=
MT_MODEL=qwen2.5:1.5b

# Run the whole pipeline with fake engines (no models loaded). For dev/tests.
# Set to 1 / true / yes to enable.
USE_FAKE_PIPELINE=
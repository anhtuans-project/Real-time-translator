# Copy this file to `.env` and fill in values. `.env` is gitignored.
# All optional — backend runs local-CPU by default when these are empty.

# Offload ASR to a GPU service (e.g. Colab notebook colab_asr_gpu.ipynb).
# Paste the tunnel WS URL printed by the notebook (Cloudflare/ngrok), e.g.:
#   wss://abcd-efg.trycloudflare.com/asr
# Leave empty to run whisper-medium locally on CPU.
ASR_REMOTE_URL=

# Offload MT (translation) to Ollama on a GPU service (same Colab notebook).
# MT_BASE_URL = the https tunnel URL (the ASR server proxies /api/* to Ollama).
# MT_MODEL = the Ollama model name you `ollama pull`-ed on Colab.
# Leave MT_BASE_URL empty to use local Ollama (http://localhost:11434, qwen2.5:1.5b).
MT_BASE_URL=
MT_MODEL=qwen2.5:1.5b

# Run the whole pipeline with fake engines (no models loaded). For dev/tests.
# Set to 1 / true / yes to enable.
USE_FAKE_PIPELINE=